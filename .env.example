# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres:admin@localhost:5432/linkedin_outreach

# API Keys (Optional - can also be set in the app)
OPENAI_API_KEY=sk-your-openai-key-here
HUGGINGFACE_TOKEN=hf_your-huggingface-token-here

# Server Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# Security
SECRET_KEY=your-secret-key-for-session-management

# LinkedIn (for advanced features - optional)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# Feature Flags
ENABLE_AUTO_POSTING=false
ENABLE_CAMPAIGNS=true
ENABLE_ANALYTICS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=linkedin_outreach.log
